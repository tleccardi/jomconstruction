---
const TESTIMONIOS = [
  {
    cita: 'Colocar testimonio',
    nombre: 'Colocar nombre',
    detalle: 'Colocar tipo de obra',
  },
  {
    cita: 'Colocar testimonio',
    nombre: 'Colocar nombre',
    detalle: 'Colocar tipo de obra',
  },
  {
    cita: 'Colocar testimonio',
    nombre: 'Colocar nombre',
    detalle: 'Colocar tipo de obra',
  },
];

// Iniciales para el monograma de autoría, derivadas del nombre. Si el campo
// queda vacío, el markup cae al ícono de respaldo (silueta).
function getIniciales(nombre: string): string {
  const limpio = nombre
    .replace(/\[[^\]]*\]/g, '') // descarta cualquier texto placeholder entre corchetes
    .replace(/[^\p{L}\s]/gu, ' ') // deja solo letras y espacios (saca cargos/empresas tras coma)
    .trim();
  if (!limpio) return '';
  const palabras = limpio.split(/\s+/).filter(Boolean);
  const primera = palabras[0]?.[0] ?? '';
  const ultima = palabras.length > 1 ? palabras[palabras.length - 1][0] : '';
  return (primera + ultima).toUpperCase();
}
---

<section class="section testimonios">
  <div class="container">
    <header class="section-head section-head--center">
      <p class="kicker reveal">Testimonios</p>
      <h2 class="section-title reveal" style="--reveal-delay: 90ms">
        Lo que dicen quienes ya construyeron con nosotros
      </h2>
    </header>

    <ul class="testimonios-grid" role="list">
      {
        TESTIMONIOS.map((testimonio, i) => {
          const iniciales = getIniciales(testimonio.nombre);
          return (
            <li
              class="testimonio reveal"
              style={`--reveal-delay: calc(120ms + var(--stagger-step) * ${i})`}
            >
              <div class="testimonio-inner">
                <blockquote>
                  <span class="testimonio-quote" aria-hidden="true">
                    <svg viewBox="0 96 448 352" fill="currentColor">
                      <path d="M0 216C0 149.7 53.7 96 120 96h8c17.7 0 32 14.3 32 32s-14.3 32-32 32h-8c-30.9 0-56 25.1-56 56v8h64c35.3 0 64 28.7 64 64v64c0 35.3-28.7 64-64 64H64c-35.3 0-64-28.7-64-64V216zm256 0c0-66.3 53.7-120 120-120h8c17.7 0 32 14.3 32 32s-14.3 32-32 32h-8c-30.9 0-56 25.1-56 56v8h64c35.3 0 64 28.7 64 64v64c0 35.3-28.7 64-64 64h-64c-35.3 0-64-28.7-64-64V216z" />
                    </svg>
                  </span>
                  <p>{testimonio.cita}</p>
                </blockquote>
                <footer>
                  <span class="testimonio-avatar" aria-hidden="true">
                    {iniciales ? (
                      iniciales
                    ) : (
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <circle cx="12" cy="8" r="3.2" />
                        <path d="M5.5 19a6.5 6.5 0 0 1 13 0" />
                      </svg>
                    )}
                  </span>
                  <span class="testimonio-autoria">
                    <strong>{testimonio.nombre}</strong>
                    <span>{testimonio.detalle}</span>
                  </span>
                </footer>
              </div>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .testimonios {
    background: var(--color-white);
  }

  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: var(--space-lg);
    max-width: 68rem; /* acota el ancho y centra: composición más contenida */
    margin-inline: auto;
    padding: 0;
    list-style: none;
  }

  /* Desktop: 3 columnas fijas. El auto-fit de arriba queda para la pasada
     mobile/tablet. */
  @media (min-width: 64em) {
    .testimonios-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---------- Kicker centrado: las dos líneas rojas se "dibujan" al entrar
     (mismo gesto que Diferenciadores/Proceso/Hero). El kicker lleva .reveal en
     el markup, así hereda el .is-visible que pone el observer global. ---------- */
  html:not(.no-js) .kicker::before,
  html:not(.no-js) .kicker::after {
    transform: scaleX(0);
  }

  /* cada línea crece hacia afuera desde el texto centrado */
  html:not(.no-js) .kicker::before {
    transform-origin: right;
  }

  html:not(.no-js) .kicker::after {
    transform-origin: left;
  }

  html:not(.no-js) .kicker.is-visible::before,
  html:not(.no-js) .kicker.is-visible::after {
    animation: testimonios-kicker-line var(--speed-cinematic) var(--ease-out) 120ms forwards;
  }

  @keyframes testimonios-kicker-line {
    to {
      transform: scaleX(1);
    }
  }

  /* La <li> solo posiciona y revela: .reveal (global.css) aporta opacity +
     translateY de entrada, escalonado por --reveal-delay. Todo el hover vive en
     .testimonio-inner para no pelear con el transform del reveal ni heredar su
     transition-delay — mismo patrón que Servicios/Diferenciadores/MetricsBar. */
  .testimonio {
    display: flex;
  }

  .testimonio-inner {
    position: relative;
    isolation: isolate;
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-lg);
    min-height: 18rem; /* cuerpo aunque la cita sea corta; crece con citas largas */
    padding: var(--space-xl);
    background: var(--color-cream);
    border: 1px solid var(--color-line);
    border-top: 2px solid var(--color-sand); /* terminación superior dorada, igual que Servicios */
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm); /* profundidad en reposo: deja de verse plana */
    transition:
      transform var(--speed-base) var(--ease-interactive),
      box-shadow var(--speed-base) var(--ease-interactive),
      border-color var(--speed-base) var(--ease-interactive);
  }

  .testimonio:hover .testimonio-inner,
  .testimonio:focus-within .testimonio-inner {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    /* sin recolorear el borde: la corona dorada superior se mantiene (igual que Servicios) */
  }

  /* ---------- Comilla: marca SVG dorada, arriba de la cita. SVG (no glifo
     tipográfico) porque su caja = la marca visible, sin hueco fantasma: la cita
     arranca justo debajo (gap fijo). Dorado --color-sand-deep, el del sitio. ---------- */
  .testimonio blockquote {
    flex-grow: 1;
    margin: 0;
  }

  .testimonio-quote {
    display: block;
    margin-bottom: var(--space-sm);
    color: var(--color-sand-deep);
    transform-origin: left center;
    transition: transform var(--speed-base) var(--ease-interactive);
  }

  .testimonio-quote svg {
    display: block;
    width: 1.75rem;
    height: auto;
  }

  .testimonio:hover .testimonio-quote,
  .testimonio:focus-within .testimonio-quote {
    transform: scale(1.06);
  }

  .testimonio blockquote p {
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    color: var(--color-ink);
  }

  /* ---------- Autoría: monograma como ancla + nombre + obra ---------- */
  .testimonio footer {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    border-top: 1px solid var(--color-line);
    padding-top: var(--space-md);
  }

  .testimonio-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-full);
    background: var(--color-cobalt);
    color: var(--color-sand-light);
    font-family: var(--font-display);
    font-size: var(--text-md);
    line-height: 1;
    letter-spacing: 0.02em;
    box-shadow: inset 0 0 0 1px rgb(228 220 176 / 0.25); /* hairline dorado */
    transition: transform var(--speed-base) var(--ease-interactive);
  }

  .testimonio-avatar svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .testimonio:hover .testimonio-avatar,
  .testimonio:focus-within .testimonio-avatar {
    transform: scale(1.06);
  }

  .testimonio-autoria {
    display: grid;
    gap: var(--space-2xs);
  }

  .testimonio footer strong {
    color: var(--color-ink);
    font-size: var(--text-base);
  }

  .testimonio-autoria span {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-sand-text);
  }

  /* prefers-reduced-motion: global.css ya neutraliza .reveal (lo deja visible) y
     lleva transiciones y animaciones a ~0ms. Así las 3 tarjetas aparecen ya
     puestas (sin cascada), la línea del kicker aparece dibujada (scaleX 1), y el
     lift + el realce de la comilla saltan a su estado final sin animar. Nada
     queda oculto detrás del movimiento: la comilla en reposo es opacity .16
     (no 0) y la cita siempre está visible. */
</style>
