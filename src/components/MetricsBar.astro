---
import { METRICS } from '../config';
---

<section class="metrics on-dark" aria-label="Cifras de trayectoria">
  <div class="container">
    <dl class="metrics-grid">
      {
        METRICS.map((metric, i) => (
          <div class="metric reveal" style={`--reveal-delay: calc(var(--stagger-step) * ${i})`}>
            <div class="metric-inner">
              <dt>{metric.label}</dt>
              <dd>
                <span class="metric-num">{metric.value}</span>
                {metric.suffix && <span class="metric-suffix">{metric.suffix}</span>}
              </dd>
            </div>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .metrics {
    position: relative;
    isolation: isolate;
    /* fondo en capas: luz cobalto arriba-centro + acento dorado tenue abajo-derecha,
       sobre la base "noche". Estático → se pinta una sola vez, cero costo en runtime. */
    background:
      radial-gradient(120% 80% at 50% 0%, rgb(255 255 255 / 0.06), transparent 55%),
      radial-gradient(90% 120% at 100% 100%, rgb(227 220 176 / 0.05), transparent 60%),
      var(--color-cobalt-night);
    border-top: 1px solid rgb(255 255 255 / 0.08);
    padding-block: clamp(2.5rem, 2rem + 3vw, 4rem);
    overflow: hidden;
  }

  /* textura "plano técnico": grilla dorada apenas perceptible, desvanecida en los
     bordes con una máscara radial para que no se lea como una tabla. On-brand. */
  .metrics::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgb(227 220 176 / 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgb(227 220 176 / 0.04) 1px, transparent 1px);
    background-size: 2.5rem 2.5rem;
    -webkit-mask-image: radial-gradient(120% 100% at 50% 50%, #000 25%, transparent 78%);
    mask-image: radial-gradient(120% 100% at 50% 50%, #000 25%, transparent 78%);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl) var(--space-lg);
    margin: 0;
  }

  .metric {
    position: relative;
    padding-inline: var(--space-lg);
  }

  /* separador vertical: gradiente dorado que se desvanece arriba y abajo (no toca
     los bordes) y "crece" con scaleY al revelar, escalonado por --reveal-delay.
     Mismo gesto que el dibujo del acento del hero, pero en vertical. */
  .metric::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1px;
    height: 62%;
    background: linear-gradient(
      to bottom,
      transparent,
      rgb(227 220 176 / 0.45),
      transparent
    );
    transform: translateY(-50%) scaleY(0);
    transform-origin: center;
    transition: transform var(--speed-slow) var(--ease-out);
    transition-delay: var(--reveal-delay, 0ms);
  }

  .metric:first-child::before {
    display: none;
  }

  .metric.is-visible::before {
    transform: translateY(-50%) scaleY(1);
  }

  /* capa interna: aísla el hover (translateY) del transform que usa .reveal en la
     entrada, así no se pelean por la misma propiedad. */
  .metric-inner {
    display: flex;
    flex-direction: column-reverse; /* la cifra (dd) arriba, la etiqueta (dt) abajo */
    gap: var(--space-sm);
    text-align: center;
    transition: transform var(--speed-base) var(--ease-interactive);
  }

  /* el lift solo con puntero fino: evita el hover "pegado" tras un tap en touch.
     En desktop con mouse (hover: hover) el resultado es idéntico al actual. */
  @media (hover: hover) {
    .metric.is-visible:hover .metric-inner {
      transform: translateY(-4px);
    }
  }

  .metric dd {
    margin: 0;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.04em;
  }

  .metric-num {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    font-variant-numeric: tabular-nums; /* ancho de dígito fijo: cifras prolijas y alineadas */
    color: var(--color-sand-light); /* fallback sólido si no hay background-clip: text */
    transition: filter var(--speed-base) var(--ease-interactive);
  }

  /* dorado "metálico" (token compartido con el acento del hero). */
  @supports ((background-clip: text) or (-webkit-background-clip: text)) {
    .metric-num {
      background: var(--gradient-gold);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
  }

  @media (hover: hover) {
    .metric.is-visible:hover .metric-num {
      filter: brightness(1.12) drop-shadow(0 4px 16px rgb(227 220 176 / 0.25));
    }
  }

  .metric-suffix {
    font-family: var(--font-display);
    font-size: var(--text-xl); /* más chico que la cifra: acento, no protagonista */
    line-height: 1;
    color: var(--color-sand);
  }

  .metric dt {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fog);
  }

  @media (min-width: 48em) {
    .metrics-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 47.99em) {
    /* R1 — columnas REALMENTE iguales. Con repeat(2, 1fr) el track es
       minmax(auto, 1fr): no baja del min-content de "185.000" (~160px), que
       forzaba la columna izquierda a ~208px y descentraba la grilla y el
       separador. minmax(0, 1fr) permite tracks idénticos. */
    .metrics-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    /* R2 — en media columna la escala display (--text-3xl ≈ 40px) no entra.
       Bajamos a --text-2xl (≈32px): sigue siendo un "headline" impactante para
       pantalla chica (Material 3 / LearnUI) y "185.000" pasa a caber holgado. */
    .metric-num {
      font-size: var(--text-2xl);
    }

    /* QW5 — sufijo un escalón más chico para conservar la proporción cifra/sufijo */
    .metric-suffix {
      font-size: var(--text-lg);
    }

    /* R3 — menos padding lateral: en una columna angosta, 24px×2 se comían el
       ancho y arrimaban la cifra al separador. */
    .metric {
      padding-inline: var(--space-xs);
    }

    /* QW4 — tracking apenas menor: alivia el wrap de etiquetas largas
       ("clientes que confiaron") en pantalla chica. */
    .metric dt {
      letter-spacing: 0.04em;
    }

    /* R4 — en 2 columnas, la de la izquierda no lleva separador. Con las
       columnas ya iguales (R1), el único separador queda centrado. */
    .metric:nth-child(odd)::before {
      display: none;
    }
  }
</style>
