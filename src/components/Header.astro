---
import { Image } from 'astro:assets';
import mark from '../assets/mark-jom-transparent.png';
import { NAV_LINKS, WHATSAPP_URL } from '../config';
---

<!-- barra de progreso de scroll: se llena según el avance de la página -->
<div class="scroll-progress" aria-hidden="true"></div>

<!-- tripwire de scroll: al salir de viewport el header pasa a estado compacto -->
<div class="header-sentinel" aria-hidden="true"></div>

<header class="header">
  <div class="container header-inner">
    <a href="#inicio" class="brand">
      <Image
        src={mark}
        alt=""
        width={51}
        height={44}
        loading="eager"
        layout="fixed"
        class="brand-mark"
      />
      <span class="brand-name">JOM <strong>Construction</strong></span>
    </a>

    <nav class="nav-desktop" aria-label="Navegación principal">
      <ul role="list">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a href="#contacto" class="btn btn--gold header-cta">Pedí tu presupuesto</a>
      <button
        type="button"
        class="menu-btn"
        aria-expanded="false"
        aria-controls="menu-mobile"
        aria-haspopup="dialog"
        data-menu-open
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <span class="visually-hidden">Abrir menú</span>
      </button>
    </div>
  </div>
</header>

<dialog id="menu-mobile" class="menu-dialog" aria-label="Menú de navegación">
  <div class="menu-top">
    <span class="brand-name">JOM <strong>Construction</strong></span>
    <button type="button" class="menu-btn" data-menu-close>
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="5" y1="5" x2="19" y2="19"></line>
        <line x1="19" y1="5" x2="5" y2="19"></line>
      </svg>
      <span class="visually-hidden">Cerrar menú</span>
    </button>
  </div>
  <nav aria-label="Navegación principal (móvil)">
    <ul role="list" class="menu-links">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} data-menu-link>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <div class="menu-ctas">
    <a href="#contacto" class="btn btn--gold" data-menu-link>Pedí tu presupuesto</a>
    <a href={WHATSAPP_URL} class="btn btn--whatsapp" target="_blank" rel="noopener">
      <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M17.5 14.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.07a8.1 8.1 0 0 1-2.39-1.47 8.95 8.95 0 0 1-1.65-2.05c-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.38-.02-.53-.08-.15-.67-1.62-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.89 1.22 3.09.15.2 2.1 3.21 5.1 4.5.71.3 1.27.49 1.7.63.72.23 1.37.2 1.88.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.9-9.88a9.83 9.83 0 0 1 9.88 9.89c0 5.45-4.44 9.88-9.89 9.88m8.41-18.29A11.82 11.82 0 0 0 12.05 0C5.5 0 .16 5.34.16 11.9c0 2.1.55 4.14 1.59 5.95L.06 24l6.3-1.65a11.9 11.9 0 0 0 5.68 1.45h.01c6.55 0 11.89-5.34 11.89-11.9 0-3.18-1.24-6.16-3.48-8.4"
        ></path>
      </svg>
      Escribinos por WhatsApp
    </a>
  </div>
</dialog>

<style>
  /* barra de progreso: fija arriba de todo, crece con scaleX según el scroll.
     transform = barato (no repinta layout); z-index por encima del header. */
  .scroll-progress {
    position: fixed;
    inset: 0 0 auto 0;
    height: 3px;
    z-index: 101;
    background: linear-gradient(90deg, var(--color-red-bright), var(--color-sand-light));
    box-shadow: 0 0 10px rgb(255 70 53 / 0.45);
    transform: scaleX(0);
    transform-origin: 0 50%;
    will-change: transform;
    pointer-events: none;
  }

  .header-sentinel {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: var(--header-h);
    pointer-events: none;
  }

  .header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: var(--header-h);
    /* sobre el hero: alto y casi transparente, sin borde */
    background: rgb(3 35 160 / 0.32);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid rgb(255 255 255 / 0);
    transition:
      height var(--speed-base) var(--ease-interactive),
      background-color var(--speed-base) var(--ease-interactive),
      border-color var(--speed-base) var(--ease-interactive),
      box-shadow var(--speed-base) var(--ease-interactive);
  }

  /* tras hacer scroll: compacto, más sólido, con borde y sombra */
  .header.is-scrolled {
    height: var(--header-h-scrolled);
    background: rgb(2 24 110 / 0.9);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: rgb(255 255 255 / 0.12);
    box-shadow: var(--shadow-header);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    height: 100%;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--color-white);
  }

  .brand-mark {
    /* marca del edificio sin fondo (PNG transparente): se apoya directo sobre el header */
    transition: transform var(--speed-base) var(--ease-interactive);
  }

  .is-scrolled .brand-mark {
    transform: scale(0.88);
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    /* mismo tratamiento que el título del hero: Marcellus en caja mixta, tracking ajustado */
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .brand-name strong {
    font-weight: 400;
    color: var(--color-sand-light);
  }

  .nav-desktop ul {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2rem);
    list-style: none;
    padding: 0;
  }

  .nav-desktop a {
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    padding-block: 0.5rem;
    background-image: linear-gradient(var(--color-sand-light), var(--color-sand-light));
    background-repeat: no-repeat;
    background-position: 50% 100%; /* crece desde el centro hacia los lados */
    background-size: 0% 2px;
    transition: background-size var(--speed-base) var(--ease-interactive);
  }

  /* subrayado dorado: hover, foco con teclado y sección activa (scrollspy) */
  .nav-desktop a:hover,
  .nav-desktop a:focus-visible,
  .nav-desktop a[aria-current] {
    background-size: 100% 2px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header-cta {
    padding: 0.625rem 1.25rem;
    min-height: 2.75rem;
  }

  .menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-sm);
    color: var(--color-white);
  }

  /* ---------- Menú mobile ---------- */
  .menu-dialog {
    width: 100%;
    max-width: 100%;
    height: 100dvh;
    max-height: 100dvh;
    margin: 0;
    padding: var(--container-pad);
    border: none;
    background: var(--color-cobalt-night);
    color: var(--color-white);
  }

  .menu-dialog::backdrop {
    background: rgb(5 19 65 / 0.6);
  }

  .menu-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-h);
  }

  .menu-top .menu-btn {
    display: inline-flex;
  }

  .menu-links {
    list-style: none;
    padding: 0;
    margin-block: var(--space-2xl);
    display: grid;
    gap: var(--space-lg);
  }

  .menu-links a {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-white);
    text-decoration: none;
  }

  .menu-links a:hover {
    color: var(--color-sand-light);
  }

  .menu-ctas {
    display: grid;
    gap: var(--space-md);
    max-width: 24rem;
  }

  @media (max-width: 56em) {
    .nav-desktop {
      display: none;
    }

    .header .menu-btn {
      display: inline-flex;
    }
  }

  @media (max-width: 30em) {
    .header-cta {
      display: none;
    }
  }
</style>

<script>
  const dialog = document.getElementById('menu-mobile') as HTMLDialogElement | null;
  const openBtn = document.querySelector<HTMLButtonElement>('[data-menu-open]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-menu-close]');

  if (dialog && openBtn) {
    openBtn.addEventListener('click', () => {
      dialog.showModal();
      openBtn.setAttribute('aria-expanded', 'true');
    });

    closeBtn?.addEventListener('click', () => dialog.close());

    // Los links de ancla cierran el menú antes de scrollear
    dialog.querySelectorAll('[data-menu-link]').forEach((link) => {
      link.addEventListener('click', () => dialog.close());
    });

    dialog.addEventListener('close', () => {
      openBtn.setAttribute('aria-expanded', 'false');
    });
  }

  // ---------- Barra de progreso de scroll ----------
  // Refleja el avance de lectura (scrollY sobre el alto desplazable). rAF para
  // no recalcular en cada evento; transform scaleX es barato y no repinta layout.
  const progressBar = document.querySelector<HTMLElement>('.scroll-progress');

  if (progressBar) {
    let ticking = false;
    const updateProgress = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = max > 0 ? Math.min(window.scrollY / max, 1) : 0;
      progressBar.style.transform = `scaleX(${ratio})`;
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(updateProgress);
          ticking = true;
        }
      },
      { passive: true }
    );
    updateProgress();
  }

  // ---------- Estado del header al hacer scroll ----------
  // Un sentinel de 1px arriba: cuando sale del viewport, el header se compacta.
  // IntersectionObserver evita un listener de scroll en cada frame.
  const header = document.querySelector<HTMLElement>('.header');
  const sentinel = document.querySelector<HTMLElement>('.header-sentinel');

  if (header && sentinel && 'IntersectionObserver' in window) {
    const headerIO = new IntersectionObserver(
      ([entry]) => header.classList.toggle('is-scrolled', !entry.isIntersecting),
      { threshold: 0 }
    );
    headerIO.observe(sentinel);
  }

  // ---------- Scrollspy: marca la sección activa en el nav (aria-current) ----------
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.nav-desktop a[href^="#"]')
  );
  const watched = navLinks
    .map((a) => {
      const section = document.getElementById(a.hash.slice(1));
      return section ? { a, section } : null;
    })
    .filter((x): x is { a: HTMLAnchorElement; section: HTMLElement } => x !== null);

  if (watched.length && 'IntersectionObserver' in window) {
    const spy = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const match = watched.find((w) => w.section === entry.target);
          if (!match) continue;
          navLinks.forEach((l) => l.removeAttribute('aria-current'));
          match.a.setAttribute('aria-current', 'true');
        }
      },
      // "activa" cuando la sección cruza la banda central del viewport
      { rootMargin: '-45% 0px -50% 0px', threshold: 0 }
    );
    watched.forEach((w) => spy.observe(w.section));
  }
</script>
