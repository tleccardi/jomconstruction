---
import { Image } from 'astro:assets';
import mark from '../assets/mark-jom.png';
import { CONTACT, NAV_LINKS, WHATSAPP_URL } from '../config';

const year = new Date().getFullYear();
---

<footer class="footer on-dark">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand reveal">
        <a href="#inicio" class="footer-logo">
          <Image src={mark} alt="" width={56} height={56} layout="fixed" />
          <span>JOM <strong>Construction</strong></span>
        </a>
        <p>
          Empresa constructora. Obra nueva, desarrollos residenciales, refacciones y obra para
          empresas.
        </p>
      </div>

      <details
        class="footer-col footer-group reveal"
        data-footer-acc
        open
        style="--reveal-delay: var(--stagger-step)"
      >
        <summary class="footer-summary">
          <h2 class="footer-title">Secciones</h2>
          <span class="footer-acc-icon" aria-hidden="true"></span>
        </summary>
        <div class="footer-acc-panel">
          <nav aria-label="Navegación del pie de página">
            <ul role="list">
              {
                NAV_LINKS.map((link) => (
                  <li>
                    <a class="footer-link" href={link.href}>
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </details>

      <details
        class="footer-col footer-group reveal"
        data-footer-acc
        open
        style="--reveal-delay: calc(var(--stagger-step) * 2)"
      >
        <summary class="footer-summary">
          <h2 class="footer-title">Contacto</h2>
          <span class="footer-acc-icon" aria-hidden="true"></span>
        </summary>
        <div class="footer-acc-panel">
          <ul role="list">
            <li>
              <a class="footer-link" href={WHATSAPP_URL} target="_blank" rel="noopener">
                WhatsApp: {CONTACT.whatsappDisplay}
              </a>
            </li>
            <li><a class="footer-link" href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></li>
            <li>{CONTACT.address}</li>
          </ul>
        </div>
      </details>

      <div
        class="footer-col footer-col--social reveal"
        style="--reveal-delay: calc(var(--stagger-step) * 3)"
      >
        <h2 class="footer-title">Redes</h2>
        <ul role="list" class="footer-social-list">
          <li>
            <a class="footer-social" href={CONTACT.instagram} rel="noopener" aria-label="Instagram">
              <span class="footer-social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none" />
                </svg>
              </span>
              <span class="footer-social-label">Instagram</span>
            </a>
          </li>
          <li>
            <a class="footer-social" href={CONTACT.linkedin} rel="noopener" aria-label="LinkedIn">
              <span class="footer-social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm6 0h3.83v1.64h.05c.53-1 1.84-2.06 3.79-2.06 4.05 0 4.8 2.67 4.8 6.14V21h-4v-5.46c0-1.3-.02-2.98-1.82-2.98-1.82 0-2.1 1.42-2.1 2.88V21H9V9Z"
                  />
                </svg>
              </span>
              <span class="footer-social-label">LinkedIn</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom reveal" style="--reveal-delay: calc(var(--stagger-step) * 4)">
      <p>© {year} JOM Construction. Todos los derechos reservados.</p>
      <p>[REEMPLAZAR: razón social y CUIT (opcional)]</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    /* un escalón por debajo de Contacto (cobalt-night): el footer lee como un plano
       más hundido y se despega del cierre, que conserva su bloom cobalto. */
    background: var(--color-cobalt-abyss);
    color: var(--color-fog);
    padding-block: var(--space-3xl) var(--space-xl);
    font-size: var(--text-sm);
  }

  .footer-grid {
    display: grid;
    /* jerarquía: marca ancha (ancla) + 3 columnas angostas.
       Scope desktop; el responsive de mobile se revisa aparte. */
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: var(--space-2xl) var(--space-xl);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    color: var(--color-white);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer-logo img {
    border-radius: var(--radius-sm);
    /* solo transform/filter: sin reflow ni layout shift */
    transition:
      transform var(--speed-base) var(--ease-interactive),
      filter var(--speed-base) var(--ease-interactive);
  }

  .footer-logo:hover img {
    transform: scale(1.04);
    filter: drop-shadow(0 0 12px rgb(228 220 176 / 0.25));
  }

  .footer-logo strong {
    font-weight: 400;
    color: var(--color-sand-light);
  }

  .footer-brand p {
    max-width: 34ch;
    margin-top: var(--space-xs);
  }

  .footer-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-sand-light);
    margin-bottom: var(--space-lg);
  }

  /* micro-acento: eco de la barrita del .kicker (global.css) para dar ritmo vertical */
  .footer-title::before {
    content: '';
    flex-shrink: 0;
    width: 1.5rem;
    height: 2px;
    background: var(--color-sand);
  }

  /* ---- Acordeón (footer) ----
     Secciones y Contacto son <details>. En DESKTOP el <summary> se neutraliza
     para verse y comportarse como el viejo <h2> de columna (siempre abierto,
     sin disclosure). El colapso vive sólo en la media query de mobile. */
  .footer-summary {
    display: block; /* bloque plano, como el viejo encabezado de columna */
    list-style: none; /* sin triángulo (estándar/Firefox) */
    cursor: default;
    pointer-events: none; /* desktop: no se togglea (queda abierto) */
  }

  .footer-summary::-webkit-details-marker {
    display: none; /* sin triángulo (WebKit) */
  }

  .footer-acc-icon {
    display: none; /* el +/− no existe en desktop */
  }

  .footer ul {
    display: grid;
    gap: var(--space-md);
    padding: 0;
    list-style: none;
    overflow-wrap: anywhere;
  }

  /* contacto: la dirección no es link → color secundario sobre la lista */
  .footer-col li {
    color: var(--color-fog);
  }

  /* Link de texto: underline que crece desde la izquierda + leve desplazamiento.
     Reemplaza el text-decoration seco. Animo solo transform/color. */
  .footer-link {
    position: relative;
    display: inline-flex;
    color: var(--color-fog);
    text-decoration: none;
    transition:
      color var(--speed-base) var(--ease-interactive),
      transform var(--speed-base) var(--ease-interactive);
  }

  .footer-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--speed-base) var(--ease-interactive);
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-white);
    transform: translateX(3px);
  }

  .footer-link:hover::after,
  .footer-link:focus-visible::after {
    transform: scaleX(1);
  }

  /* Redes: ícono en chip circular + label. Hover enciende borde/color y leva el chip. */
  .footer-social-list {
    gap: var(--space-md);
  }

  .footer-social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-fog);
    text-decoration: none;
    transition: color var(--speed-base) var(--ease-interactive);
  }

  .footer-social-icon {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-full);
    border: 1px solid rgb(255 255 255 / 0.14);
    transition:
      border-color var(--speed-base) var(--ease-interactive),
      background-color var(--speed-base) var(--ease-interactive),
      transform var(--speed-base) var(--ease-interactive);
  }

  .footer-social-icon svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .footer-social:hover,
  .footer-social:focus-visible {
    color: var(--color-sand-light);
  }

  .footer-social:hover .footer-social-icon,
  .footer-social:focus-visible .footer-social-icon {
    border-color: var(--color-sand-light);
    background: rgb(228 220 176 / 0.08);
    transform: translateY(-2px);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-top: var(--space-3xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgb(255 255 255 / 0.1);
    color: var(--color-fog);
    font-size: var(--text-xs);
  }

  /* ============================================================
     MOBILE (≤47.99em) — el desktop (≥48em) NO se toca.
     Cierre de marca: marca + descripción, redes como chips
     cuadrados ícono-solo, y Secciones/Contacto como acordeones.
     ============================================================ */
  @media (max-width: 47.99em) {
    .footer {
      /* cadencia de reveal más calma: apilados, los bloques entran juntos */
      --stagger-step: 60ms;
      /* reserva inferior para que la barra sticky de WhatsApp
         (StickyContact, ≈4.5rem de alto) no tape el copyright +
         razón social. 7rem deja ~2rem de aire; + safe-area iOS. */
      padding-bottom: calc(
        var(--space-3xl) + var(--space-2xl) + env(safe-area-inset-bottom, 0px)
      );
    }

    /* stack de 1 columna + reorden visual: marca → redes → secciones → contacto.
       El orden del DOM se conserva (para desktop); acá sólo reordena `order`. */
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .footer-brand {
      order: 1;
      padding-bottom: var(--space-lg);
    }

    .footer-brand p {
      max-width: none;
    }

    .footer-col--social {
      order: 2;
      padding-bottom: var(--space-md);
    }

    .footer-group {
      order: 3;
      /* hairline divisor entre filas del acordeón (y respecto de las redes) */
      border-top: 1px solid rgb(255 255 255 / 0.1);
    }

    /* ---- Redes: chips cuadrados, sólo ícono, en fila ---- */
    /* el título "Redes" se oculta a la vista pero queda para lectores de pantalla */
    .footer-col--social .footer-title {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      border: 0;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }

    /* gana al display:grid de `.footer ul` por especificidad */
    .footer-col--social .footer-social-list {
      display: flex;
      gap: var(--space-sm);
    }

    .footer-social-label {
      display: none; /* sólo ícono; el nombre accesible lo da aria-label */
    }

    .footer-col--social .footer-social-icon {
      width: 2.75rem; /* chip cuadrado 44px = target táctil */
      height: 2.75rem;
      border-radius: var(--radius-md);
    }

    /* ---- Acordeones (Secciones / Contacto) ---- */
    .footer-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-md);
      padding-block: var(--space-md); /* fila táctil ≥44px */
      cursor: pointer;
      pointer-events: auto; /* re-habilita el toggle nativo en mobile */
    }

    /* dentro del summary el título no necesita su margen de columna desktop */
    .footer-summary .footer-title {
      margin-bottom: 0;
    }

    /* +/− construido con pseudo-elementos (afordancia de disclosure, no un ícono de marca) */
    .footer-acc-icon {
      position: relative;
      display: block;
      flex-shrink: 0;
      width: 1rem;
      height: 1rem;
      color: var(--color-sand-light);
    }

    .footer-acc-icon::before,
    .footer-acc-icon::after {
      content: '';
      position: absolute;
      inset: 0;
      margin: auto;
      background: currentColor;
      transition: transform var(--speed-base) var(--ease-interactive);
    }

    .footer-acc-icon::before {
      width: 100%;
      height: 1.5px;
    }

    .footer-acc-icon::after {
      width: 1.5px;
      height: 100%;
    }

    /* abierto: la barra vertical colapsa → el + se vuelve − (movimiento discreto) */
    .footer-group[open] .footer-acc-icon::after {
      transform: scaleY(0);
    }

    /* espacio al pie del panel abierto, antes del siguiente hairline */
    .footer-acc-panel {
      padding-bottom: var(--space-lg);
    }

    /* targets táctiles cómodos (≥44px) + subrayado reanclado bajo el texto */
    .footer-link {
      padding-block: var(--space-sm);
    }

    .footer-link::after {
      bottom: calc(var(--space-sm) - 2px);
    }

    /* barra inferior: copyright y razón social apilados a la izquierda */
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
      margin-top: var(--space-lg);
    }
  }
</style>

<script>
  // Acordeón del footer: colapsable SÓLO en mobile. En desktop los <details>
  // quedan abiertos (se ven como columnas). Sin JS, el atributo `open` del HTML
  // deja todo el contenido visible en ambos tamaños (degradación correcta).
  const accs = document.querySelectorAll<HTMLDetailsElement>('[data-footer-acc]');

  if (accs.length > 0) {
    const mq = window.matchMedia('(max-width: 47.99em)');
    const sync = () => {
      accs.forEach((d) => {
        const summary = d.querySelector('summary');
        if (mq.matches) {
          // mobile: acordeón real (colapsado, sumario navegable por teclado)
          d.removeAttribute('open');
          summary?.removeAttribute('tabindex');
        } else {
          // desktop: abierto y sumario inerte (fuera del tab), como el viejo <h2>
          d.setAttribute('open', '');
          summary?.setAttribute('tabindex', '-1');
        }
      });
    };
    sync();
    mq.addEventListener('change', sync);
  }
</script>
