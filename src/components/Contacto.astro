---
import { CONTACT, WHATSAPP_URL } from '../config';

const TIPOS_PROYECTO = [
  'Obra nueva',
  'Refacción o ampliación',
  'Desarrollo inmobiliario',
  'Obra para mi empresa',
  'Otro / no estoy seguro',
];
---

<section id="contacto" class="section contacto on-dark">
  <div class="container contacto-grid">
    <div class="contacto-info">
      <header class="section-head contacto-head">
        <p class="kicker reveal">Contacto</p>
        <h2 class="section-title reveal" style="--reveal-delay: calc(var(--stagger-step) * 1)">
          Pedí tu presupuesto sin cargo
        </h2>
        <p class="section-lede reveal" style="--reveal-delay: calc(var(--stagger-step) * 2)">
          Contanos qué querés construir o refaccionar. Te respondemos dentro de las 24 hs hábiles
          con los próximos pasos. Sin compromiso.
        </p>
      </header>

      <ul class="contacto-canales" role="list">
        <li class="reveal" style="--reveal-delay: calc(var(--stagger-step) * 3)">
          <a href={WHATSAPP_URL} class="btn btn--whatsapp" target="_blank" rel="noopener">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M17.5 14.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.07a8.1 8.1 0 0 1-2.39-1.47 8.95 8.95 0 0 1-1.65-2.05c-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.38-.02-.53-.08-.15-.67-1.62-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.89 1.22 3.09.15.2 2.1 3.21 5.1 4.5.71.3 1.27.49 1.7.63.72.23 1.37.2 1.88.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.9-9.88a9.83 9.83 0 0 1 9.88 9.89c0 5.45-4.44 9.88-9.89 9.88m8.41-18.29A11.82 11.82 0 0 0 12.05 0C5.5 0 .16 5.34.16 11.9c0 2.1.55 4.14 1.59 5.95L.06 24l6.3-1.65a11.9 11.9 0 0 0 5.68 1.45h.01c6.55 0 11.89-5.34 11.89-11.9 0-3.18-1.24-6.16-3.48-8.4"
              ></path>
            </svg>
            Escribinos por WhatsApp
          </a>
          <span class="canal-nota">Respuesta rápida en horario laboral</span>
        </li>
        <li class="canal-dato reveal" style="--reveal-delay: calc(var(--stagger-step) * 4)">
          <span class="canal-label">Email</span>
          <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        </li>
        <li class="canal-dato reveal" style="--reveal-delay: calc(var(--stagger-step) * 5)">
          <span class="canal-label">WhatsApp</span>
          <span>{CONTACT.whatsappDisplay}</span>
        </li>
      </ul>
    </div>

    <form class="contacto-form reveal" style="--reveal-delay: 200ms" action={CONTACT.formEndpoint} method="POST">
      <h3>Dejanos tus datos</h3>

      <div class="campo">
        <label for="f-nombre">Nombre</label>
        <input id="f-nombre" name="nombre" type="text" required autocomplete="name" autocapitalize="words" />
      </div>

      <div class="campo">
        <label for="f-telefono">WhatsApp o teléfono</label>
        <input
          id="f-telefono"
          name="telefono"
          type="tel"
          required
          autocomplete="tel"
          inputmode="tel"
          aria-describedby="f-telefono-nota"
        />
        <p class="campo-nota" id="f-telefono-nota">
          Lo usamos solo para coordinar tu presupuesto. No enviamos spam.
        </p>
      </div>

      <div class="campo">
        <label for="f-tipo">Tipo de proyecto</label>
        <select id="f-tipo" name="tipo_de_proyecto" required>
          <option value="" disabled selected>Elegí una opción</option>
          {TIPOS_PROYECTO.map((tipo) => <option value={tipo}>{tipo}</option>)}
        </select>
      </div>

      <div class="campo">
        <label for="f-localidad">Localidad <span class="opcional">(opcional)</span></label>
        <input id="f-localidad" name="localidad" type="text" autocomplete="address-level2" autocapitalize="words" />
      </div>

      <div class="campo">
        <label for="f-mensaje">Contanos tu proyecto <span class="opcional">(opcional)</span></label>
        <textarea id="f-mensaje" name="mensaje" rows="4" autocapitalize="sentences"></textarea>
      </div>

      <!-- Honeypot anti-spam de Formspree: oculto para humanos -->
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="gotcha" aria-hidden="true" />
      <input type="hidden" name="_subject" value="Nuevo pedido de presupuesto — Landing JOM Construction" />

      <button type="submit" class="btn btn--primary form-submit">
        Quiero mi presupuesto
        <svg class="form-submit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h13M13 6l6 6-6 6"></path>
        </svg>
      </button>
      <p class="form-nota">
        Al enviar aceptás que te contactemos por los datos que dejaste. Nada más.
      </p>
    </form>
  </div>

  <div class="contacto-seam reveal" aria-hidden="true"></div>
</section>

<style>
  .contacto {
    position: relative; /* ancla la costura de cierre (::after via .contacto-seam) */
    background:
      radial-gradient(80rem 40rem at 110% -10%, rgb(3 40 185 / 0.55), transparent 60%),
      var(--color-cobalt-night);
  }

  /* ---------- Costura Contacto → Footer ----------
     Hairline dorado a tope con el footer (que baja a --color-cobalt-abyss). Se "dibuja"
     con scaleX al entrar, mismo gesto que el separador de MetricsBar y el acento del Hero.
     Se desvanece en los extremos para no leer como borde duro. */
  .contacto-seam {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-sand) 16%,
      var(--color-sand-light) 50%,
      var(--color-sand) 84%,
      transparent
    );
    transform-origin: center;
  }

  /* reutiliza la transición y el --reveal-delay de .reveal: solo dibuja con scaleX (sin fade) */
  .contacto-seam.reveal {
    opacity: 1;
    transform: scaleX(0);
  }

  .contacto-seam.reveal.is-visible {
    transform: none;
  }

  /* sin JS la costura no recibe .is-visible: la dejamos trazada */
  :global(html.no-js) .contacto-seam.reveal {
    transform: none;
  }

  .contacto-grid {
    display: grid;
    gap: var(--space-2xl);
    align-items: start;
  }

  .contacto-head {
    margin-bottom: var(--space-xl);
  }

  /* línea del kicker: se "dibuja" (scaleX) al revelar, en vez de estar quieta.
     Guardada con html:not(.no-js) para que sin JS quede la barra roja estática. */
  :global(html:not(.no-js)) .contacto .kicker::before {
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--speed-slow) var(--ease-out);
    transition-delay: var(--reveal-delay, 0ms);
  }

  :global(html:not(.no-js)) .contacto .kicker.is-visible::before {
    transform: scaleX(1);
  }

  .contacto-canales {
    display: grid;
    gap: var(--space-lg);
    padding: 0;
    list-style: none;
  }

  .canal-nota {
    display: block;
    margin-top: var(--space-xs);
    font-size: var(--text-xs);
    color: var(--color-fog);
  }

  .canal-dato {
    display: grid;
    gap: var(--space-2xs);
    padding-top: var(--space-md);
    border-top: 1px solid rgb(255 255 255 / 0.12);
    overflow-wrap: anywhere;
  }

  /* combina la entrada del .reveal (opacity/transform + --reveal-delay del stagger) con
     el feedback de hover del borde, sin que la transición de hover pise a la de entrada */
  .canal-dato.reveal {
    transition:
      opacity var(--speed-slow) var(--ease-out) var(--reveal-delay, 0ms),
      transform var(--speed-slow) var(--ease-out) var(--reveal-delay, 0ms),
      border-top-color var(--speed-base) var(--ease-interactive);
  }

  /* al pasar el cursor, la línea superior del dato se aviva (feedback sin transform,
     para no pelear con el translateY del .reveal en la misma <li>) */
  .canal-dato:hover {
    border-top-color: var(--color-sand-light);
  }

  .canal-label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-sand-light);
  }

  .canal-dato a,
  .canal-dato span:not(.canal-label) {
    color: var(--color-white);
    font-weight: 600;
  }

  /* subrayado dorado que se desliza en hover/focus (en vez del subrayado fijo) */
  .canal-dato a {
    text-decoration: none;
    background-image: linear-gradient(var(--color-sand-light), var(--color-sand-light));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 1.5px;
    transition: background-size var(--speed-base) var(--ease-out);
  }

  .canal-dato a:hover,
  .canal-dato a:focus-visible {
    background-size: 100% 1.5px;
  }

  /* ---------- Formulario (tarjeta) ---------- */
  .contacto-form {
    /* la tarjeta es blanca dentro de una sección oscura: el anillo de foco vuelve a cobalto */
    --color-focus: var(--color-cobalt);
    position: relative; /* contexto para el anillo de foco / sombra */
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: var(--color-white);
    border: 1px solid var(--color-line); /* canto crispado incluso en pantallas brillantes */
    /* terminación superior dorada, IGUAL que Servicios: un borde real
       sigue el radio de la card y no asoma en las esquinas (a diferencia de un
       ::before de 3px con radio grande, que dejaba nubcitos dorados arriba). */
    border-top: 2px solid var(--color-sand);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  /* La tarjeta entra como bloque, con más recorrido que el .reveal base (co-protagonista).
     El --reveal-delay solo afecta a opacity/transform: el box-shadow del focus-within
     responde al instante. No transformo en focus-within (regla de la casa: no pelear
     con el transform del .reveal — ver Servicios). */
  .contacto-form.reveal {
    transform: translateY(32px);
    transition:
      opacity var(--speed-slow) var(--ease-out) var(--reveal-delay, 0ms),
      transform var(--speed-slow) var(--ease-out) var(--reveal-delay, 0ms),
      box-shadow var(--speed-base) var(--ease-interactive);
  }

  .contacto-form.reveal.is-visible {
    transform: none;
  }

  :global(html.no-js) .contacto-form.reveal {
    transform: none;
  }

  /* al enfocar cualquier campo, la tarjeta se eleva: anillo cobalto + sombra más profunda */
  .contacto-form:focus-within {
    box-shadow:
      0 0 0 1px rgb(3 40 185 / 0.35),
      0 8px 20px rgb(5 19 65 / 0.14),
      0 32px 64px rgb(5 19 65 / 0.22);
  }

  .contacto-form h3 {
    font-size: var(--text-lg);
    color: var(--color-ink);
    margin-bottom: var(--space-lg);
  }

  .campo {
    margin-bottom: var(--space-md);
  }

  .campo label {
    display: block;
    margin-bottom: var(--space-2xs);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
    transition: color var(--speed-fast) var(--ease-out);
  }

  /* el label del campo activo vira a cobalto: refuerza dónde está el foco */
  .campo:focus-within label {
    color: var(--color-cobalt);
  }

  .opcional {
    font-weight: 400;
    color: var(--color-slate);
  }

  .campo input,
  .campo select,
  .campo textarea {
    width: 100%;
    min-height: 3rem;
    padding: 0.75rem 1rem;
    font-size: 1rem; /* ≥16px: evita el zoom forzado de iOS */
    color: var(--color-ink);
    background: var(--color-white);
    border: 1.5px solid var(--color-line);
    border-radius: var(--radius-sm);
    transition:
      border-color var(--speed-fast) var(--ease-out),
      box-shadow var(--speed-fast) var(--ease-out);
  }

  .campo textarea {
    resize: vertical;
  }

  /* hover (sin foco): el borde se oscurece para señalar que el campo es interactivo */
  .campo input:hover,
  .campo select:hover,
  .campo textarea:hover {
    border-color: var(--color-slate);
  }

  /* foco (mouse o teclado): borde cobalto (indicador ≥3:1) + halo suave que entra */
  .campo input:focus,
  .campo select:focus,
  .campo textarea:focus {
    border-color: var(--color-cobalt);
    box-shadow: var(--ring-focus);
  }

  /* foco de teclado: además del halo, el outline nítido del sistema (WCAG 2.4.7) */
  .campo input:focus-visible,
  .campo select:focus-visible,
  .campo textarea:focus-visible {
    outline: 3px solid var(--color-cobalt);
    outline-offset: 1px;
  }

  .campo-nota {
    margin-top: var(--space-2xs);
    font-size: var(--text-xs);
    color: var(--color-slate);
  }

  .gotcha {
    display: none !important;
  }

  .form-submit {
    width: 100%;
    margin-top: var(--space-sm);
  }

  /* flecha del CTA: se desplaza a la derecha en hover (clase propia para no heredar
     el micro-zoom de .btn-icon) */
  .form-submit-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    transition: transform var(--speed-base) var(--ease-interactive);
  }

  .form-submit:hover .form-submit-icon {
    transform: translateX(3px);
  }

  .form-nota {
    margin-top: var(--space-sm);
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-slate);
  }

  @media (min-width: 64em) {
    .contacto-grid {
      grid-template-columns: 6fr 5fr;
      gap: var(--space-3xl);
    }
  }

  /* ---------- Mobile (≤47.99em): WhatsApp primero, form con más aire ----------
     Se respeta el orden natural del HTML (head → canales → form), así el
     WhatsApp y los datos quedan primeros en una columna y el form cierra.
     Todo vive en <48em: el desktop (6fr/5fr desde 64em) y el tablet (≥48em)
     no se tocan. */
  @media (max-width: 47.99em) {
    /* cada .reveal se observa por separado, así que los delays largos
       (calc(--stagger-step * 6) en los canales) se sienten lentos en una
       columna. Bajar el paso recalcula los calc() inline sin tocar el HTML. */
    .contacto {
      --stagger-step: 45ms;
    }

    /* más respiración entre campos y entre label y campo en una columna */
    .campo {
      margin-bottom: var(--space-lg);
    }

    .campo label {
      margin-bottom: var(--space-xs);
    }
  }
</style>
