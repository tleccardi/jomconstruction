---
import { Image } from 'astro:assets';
import fotoPanoramica from '../assets/obra-aerea-panoramica.jpg';
import fotoEstructuras from '../assets/obra-estructuras.jpg';
import fotoCenital from '../assets/obra-vista-cenital.jpg';
import lgEstructuraBomba from '../assets/leon-gallo-estructura-bomba.jpeg';
import lgEstructura from '../assets/leon-gallo-estructura.jpeg';
import lgFundacionesBases from '../assets/leon-gallo-fundaciones-bases.jpeg';
import lgExcavacion from '../assets/leon-gallo-excavacion.jpeg';
import lgFundacionesMembrana from '../assets/leon-gallo-fundaciones-membrana.jpeg';
import hotelBahia from '../assets/hotel-cilene-1-bahia.jpeg';
import hotelExcavacion from '../assets/hotel-cilene-2-excavacion.jpeg';
import hotelHormigonado from '../assets/hotel-cilene-3-hormigonado.jpeg';
import hotelHormigonera from '../assets/hotel-cilene-4-hormigonera.jpeg';
import pgCanal from '../assets/pesquera-glaciar-1-canal.jpeg';
import pgExcavacion from '../assets/pesquera-glaciar-2-excavacion.jpeg';
import pgEstructura from '../assets/pesquera-glaciar-3-estructura.jpeg';
import pgEncofrados from '../assets/pesquera-glaciar-4-encofrados.jpeg';
import pgHormigonado from '../assets/pesquera-glaciar-5-hormigonado.jpeg';
import pgBomba from '../assets/pesquera-glaciar-6-bomba.jpeg';
import pgLosaNevada from '../assets/pesquera-glaciar-7-losa-nevada.jpeg';
import pgMetalicaMar from '../assets/pesquera-glaciar-8-metalica-mar.jpeg';
import pgMetalicaIzado from '../assets/pesquera-glaciar-9-metalica-izado.jpeg';
import pgMetalicaInterior from '../assets/pesquera-glaciar-10-metalica-interior.jpeg';
import pgColumnas from '../assets/pesquera-glaciar-11-columnas.jpeg';
import pgDeckPueblo from '../assets/pesquera-glaciar-12-deck-pueblo.jpeg';
import pgArmadura from '../assets/pesquera-glaciar-13-armadura.jpeg';
import pgTormenta from '../assets/pesquera-glaciar-14-tormenta-nieve.jpeg';

// ============================================================
// DATA: una entrada por obra. Para sumar obras a futuro basta
// con agregar un item a OBRAS (cada uno trae su set de fotos y
// su ficha). El selector de obras (tabs) y el lightbox se
// construyen solos a partir de este array.
// ============================================================
type DatoObra = {
  label: string;
  value: string;
  destacado?: boolean; // cifra grande en tipografía display (m², año…)
  estado?: boolean; // pill "en ejecución" con punto latiente
  finalizada?: boolean; // pill "finalizada" con check (sin latido)
};
type Foto = { src: ImageMetadata; alt: string; caption: string };
type Obra = {
  id: string;
  nombreCorto: string; // etiqueta del tab
  meta: string; // 2ª línea del tab (ubicación · año)
  titulo: string; // <h3> del panel
  descripcion: string;
  datos: DatoObra[];
  fotos: Foto[]; // [0] es la principal; el resto son miniaturas
};

const OBRAS: Obra[] = [
  {
    id: 'leon-gallo',
    nombreCorto: 'Desarrollo residencial',
    meta: 'San Justo, Bs. As. · 2026',
    titulo: 'Desarrollo residencial — León Gallo, San Justo',
    descripcion:
      'Conjunto de edificios de vivienda en altura media, ejecutado por etapas: estructura de hormigón armado, mampostería y fundaciones de las torres siguientes avanzando en paralelo.',
    // Año y Estado son PROVISORIOS — los ajusta el cliente.
    datos: [
      { label: 'Tipo de obra', value: 'Obra nueva — desarrollo residencial' },
      { label: 'Ubicación', value: 'León Gallo, San Justo — La Matanza, Buenos Aires' },
      { label: 'Año', value: '2026', destacado: true },
      { label: 'Estado', value: 'En ejecución — entrega 2027', estado: true },
    ],
    // 8 fotos: tomas aéreas del conjunto + la torre en altura + las fundaciones
    // de las próximas etapas. El mosaico destaca 6; el resto va al lightbox ("+N").
    fotos: [
      {
        src: fotoPanoramica,
        alt: 'Vista aérea panorámica del desarrollo residencial: varios edificios de media altura en etapa de estructura',
        caption: 'Vista aérea del conjunto — edificios en etapa de estructura',
      },
      {
        src: lgEstructuraBomba,
        alt: 'Edificio de varias plantas en estructura de hormigón armado mientras un camión bomba hormigona el último nivel, con armaduras de hierro y el barrio de San Justo alrededor',
        caption: 'Hormigonado en altura: la bomba alcanzando el último nivel de la torre',
      },
      {
        src: fotoEstructuras,
        alt: 'Edificios en construcción con estructuras de hormigón armado y mampostería, junto al sector de fundaciones',
        caption: 'Estructuras de hormigón armado y fundaciones de las próximas etapas',
      },
      {
        src: lgEstructura,
        alt: 'Edificio de viviendas de varios niveles en estructura de hormigón armado bajo un cielo despejado, con operarios y encofrados en primer plano',
        caption: 'La torre en estructura de hormigón armado, etapa avanzada',
      },
      {
        src: fotoCenital,
        alt: 'Vista cenital de la obra: tres edificios en construcción y las plateas de fundación del resto del predio',
        caption: 'Vista cenital del predio completo y plateas de fundación',
      },
      {
        src: lgFundacionesBases,
        alt: 'Encofrado de madera para la base de una columna sobre el hormigón de fundación, con armaduras de hierro en espera y el entorno urbano de San Justo al fondo',
        caption: 'Encofrado de bases y fundaciones sobre el hormigón fresco',
      },
      {
        src: lgExcavacion,
        alt: 'Operario de pie en una excavación profunda de fundaciones revestida con membrana de impermeabilización, en el predio urbano de San Justo',
        caption: 'Excavación de fundaciones revestida con membrana',
      },
      {
        src: lgFundacionesMembrana,
        alt: 'Zanjas de fundación excavadas y cubiertas con membrana de impermeabilización, con un camión volcador y un operario, en el predio de San Justo',
        caption: 'Fundaciones impermeabilizadas y movimiento de suelos',
      },
    ],
  },
  {
    id: 'hotel-cilene',
    nombreCorto: 'Hotel Cilene del Faro',
    meta: 'Tierra del Fuego · 2007',
    titulo: 'Hotel Cilene del Faro Suites & Spa',
    descripcion:
      'Hotel & spa en Tierra del Fuego. JOM ejecutó la obra desde el movimiento de suelos y las fundaciones hasta la estructura, hormigonando en pleno invierno fueguino, sobre la bahía y al pie de los cerros nevados.',
    datos: [
      { label: 'Tipo de obra', value: 'Obra nueva — hotel & spa' },
      { label: 'Ubicación', value: 'Tierra del Fuego, Argentina' },
      { label: 'Año', value: '2007', destacado: true },
      { label: 'Estado', value: 'Finalizada', finalizada: true },
    ],
    fotos: [
      {
        src: hotelBahia,
        alt: 'Fundaciones del hotel sobre la bahía de Tierra del Fuego: operarios y una excavadora JOM trabajando entre armaduras de hierro, con el mar y los cerros nevados de fondo',
        caption: 'Fundaciones sobre la bahía — armaduras y la cordillera fueguina de fondo',
      },
      {
        src: hotelExcavacion,
        alt: 'Excavadora naranja de JOM cargando tierra en un camión volcador durante el movimiento de suelos, con el edificio del hotel de techos a dos aguas detrás',
        caption: 'Movimiento de suelos — excavadora JOM cargando el volquete',
      },
      {
        src: hotelHormigonado,
        alt: 'Camión bomba hormigonando los encofrados de madera del hotel durante una nevada, con la estructura protegida por lonas',
        caption: 'Hormigonado de la estructura en plena nevada',
      },
      {
        src: hotelHormigonera,
        alt: 'Camión hormigonero y excavadora de JOM trabajando junto al edificio del hotel sobre la nieve, con encofrados y armaduras en primer plano',
        caption: 'Hormigonera y excavadora JOM al pie del hotel',
      },
    ],
  },
  {
    id: 'pesquera-glaciar',
    nombreCorto: 'Glaciar Pesquera',
    meta: 'Ushuaia · 2007',
    titulo: 'Planta Glaciar Pesquera — Ushuaia',
    descripcion:
      'Planta de procesamiento y frigorífico para Glaciar Pesquera, sobre la costa del canal Beagle en Ushuaia. JOM ejecutó la obra desde el movimiento de suelos y las fundaciones hasta la estructura de hormigón armado, las losas y el montaje de la estructura metálica de las naves, trabajando a metros del mar y del puerto, en pleno clima fueguino.',
    // Año PROVISORIO (2007, misma época que el Hotel Cilene) — confirmar con el cliente.
    datos: [
      { label: 'Tipo de obra', value: 'Obra nueva — planta pesquera & frigorífico' },
      { label: 'Ubicación', value: 'Ushuaia, Tierra del Fuego' },
      { label: 'Año', value: '2007', destacado: true },
      { label: 'Estado', value: 'Finalizada', finalizada: true },
    ],
    // 14 fotos en dos etapas (obra civil + estructura metálica). El mosaico
    // destaca 6 (izaje y nevada incluidas); el resto se ve en el lightbox vía "+N".
    fotos: [
      {
        src: pgCanal,
        alt: 'Vista elevada de la planta en construcción sobre el canal Beagle: operarios terminando una losa de hormigón sobre los encofrados, con catamaranes en el puerto de Ushuaia y los galpones de la pesquera al fondo',
        caption: 'La planta en construcción sobre el canal Beagle, junto al puerto de Ushuaia',
      },
      {
        src: pgMetalicaIzado,
        alt: 'Una grúa iza una cabriada de acero para montarla sobre los pórticos de la nave, con los operarios guiándola desde la base de hormigón y el canal Beagle al atardecer de fondo',
        caption: 'Izaje de una cabriada de acero sobre el canal Beagle',
      },
      {
        src: pgTormenta,
        alt: 'Operarios trabajando sobre la losa durante una intensa nevada, empujando una zorra entre las esperas de hierro, cubiertos de nieve en pleno temporal fueguino',
        caption: 'El equipo en plena nevada, trabajando con temporal sobre la losa',
      },
      {
        src: pgExcavacion,
        alt: 'Hormigonado de las fundaciones en una excavación profunda: un camión grúa baja el balde de hormigón mientras los operarios trabajan entre las armaduras, con el monte nevado de fondo',
        caption: 'Fundaciones: hormigonado en la excavación, con la montaña fueguina detrás',
      },
      {
        src: pgBomba,
        alt: 'Camión bomba de hormigón en primer plano y una grúa elevando el balde sobre la estructura, con los catamaranes del puerto y los galpones de la pesquera sobre el canal Beagle',
        caption: 'Bomba y grúa hormigonando, frente al puerto y los galpones de la pesquera',
      },
      {
        src: pgMetalicaMar,
        alt: 'Operarios montando la estructura metálica de la nave: pórticos de acero blanco sobre la base de hormigón, con el canal Beagle y un bote pesquero de fondo',
        caption: 'Montaje de la estructura metálica sobre la base de hormigón',
      },
      {
        src: pgEstructura,
        alt: 'Vista en altura de la estructura: muros de hormigón encofrados y la malla de hierro de la losa, con operarios trabajando sobre el nivel superior',
        caption: 'Estructura de hormigón armado — encofrados y armadura de la losa',
      },
      {
        src: pgColumnas,
        alt: 'Estructura en sus primeras etapas: tabiques de hormigón con las columnas de hierro en espera y operarios sobre el nivel, con el canal Beagle y los cerros nevados de fondo',
        caption: 'Tabiques y columnas en espera, frente al canal Beagle',
      },
      {
        src: pgHormigonado,
        alt: 'Operarios hormigonando una columna desde el balde de una grúa, sobre los encofrados de madera, con los cerros nevados de Ushuaia de fondo',
        caption: 'Hormigonado de columnas sobre los encofrados, al pie de los cerros nevados',
      },
      {
        src: pgEncofrados,
        alt: 'Muros de hormigón encofrados elevándose junto a la costa, con un camión grúa de JOM bajando el balde de hormigón y el canal Beagle de fondo',
        caption: 'Muros encofrados al borde del canal, con la grúa de JOM en plena tarea',
      },
      {
        src: pgDeckPueblo,
        alt: 'Vista elevada de la losa con operarios trabajando y, al fondo, el pueblo de Ushuaia, una embarcación botándose con grúa y el casco de un barco varado sobre la costa',
        caption: 'La losa en obra, con el pueblo y la costa de Ushuaia de fondo',
      },
      {
        src: pgArmadura,
        alt: 'Detalle de las armaduras de hierro de las vigas y encadenados montadas sobre la losa, listas para hormigonar, con el pueblo de Ushuaia al fondo',
        caption: 'Armaduras de hierro de las vigas, listas para hormigonar',
      },
      {
        src: pgLosaNevada,
        alt: 'Losa de hormigón terminada y cubierta de nieve, con las esperas de hierro de la próxima etapa, frente al edificio existente y los cerros nevados de Ushuaia',
        caption: 'La losa terminada bajo la nieve, lista para la etapa siguiente',
      },
      {
        src: pgMetalicaInterior,
        alt: 'Vista interior de la nave en montaje, entre los pórticos de acero blanco, con la base de hormigón y el canal Beagle de fondo',
        caption: 'Interior de la nave durante el montaje de la estructura metálica',
      },
    ],
  },
];
---

<section id="obras" class="section obras">
  <div class="container">
    <header class="section-head">
      <p class="kicker reveal">Obras</p>
      <h2 class="section-title reveal" style="--reveal-delay: calc(var(--stagger-step) * 1)">
        La prueba está en la obra
      </h2>
      <p class="section-lede reveal" style="--reveal-delay: calc(var(--stagger-step) * 2)">
        Sin renders ni fotos de archivo: documentamos lo que construimos. Elegí una obra para
        recorrerla en detalle, de un desarrollo residencial en Buenos Aires a obras de gran porte
        en Tierra del Fuego.
      </p>
    </header>

    {/* Selector de obras (patrón WAI-ARIA Tabs, activación automática).
        Sin JS se oculta y los paneles quedan apilados (ver bloque html.no-js). */}
    <div
      class="obra-tabs reveal"
      role="tablist"
      aria-label="Obras de JOM Construction"
      style="--reveal-delay: calc(var(--stagger-step) * 3)"
    >
      {
        OBRAS.map((obra, i) => (
          <button
            type="button"
            role="tab"
            id={`tab-${obra.id}`}
            class="obra-tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${obra.id}`}
            tabindex={i === 0 ? 0 : -1}
          >
            <span class="obra-tab-nombre">{obra.nombreCorto}</span>
            <span class="obra-tab-meta">{obra.meta}</span>
          </button>
        ))
      }
    </div>

    {
      OBRAS.map((obra, oi) => {
        // Galería "mosaico" cuando hay muchas fotos (≥6): la principal ocupa un
        // bloque 2×2 y otras 5 completan una grilla 3×3 (9 celdas). Con menos
        // fotos se usa el layout clásico (principal + fila de miniaturas), intacto.
        const mosaico = obra.fotos.length >= 6;
        // El mosaico muestra como máximo 6 fotos (1 principal + 5 miniaturas).
        // Si hay más, la última miniatura lleva un "+N" que abre el lightbox con
        // TODAS (patrón galería tipo Airbnb: selección curada + ver todas).
        const MOSAICO_VISIBLE = 6;
        const thumbsTodas = obra.fotos.slice(1);
        const thumbsVisibles = mosaico
          ? thumbsTodas.slice(0, MOSAICO_VISIBLE - 1)
          : thumbsTodas;
        const fotosOcultas = thumbsTodas.length - thumbsVisibles.length;
        // sizes de las miniaturas: en mosaico cada una ocupa ~1/3 del ancho;
        // en el layout clásico se reparten la fila según cuántas haya.
        const thumbCount = Math.max(obra.fotos.length - 1, 1);
        const thumbPx = Math.round(1104 / thumbCount);
        const thumbVw = Math.round(100 / thumbCount);
        const thumbSizes = mosaico
          ? '(min-width: 72em) 368px, (min-width: 48em) 33vw, calc(100vw - 2.5rem)'
          : `(min-width: 72em) ${thumbPx}px, (min-width: 48em) ${thumbVw}vw, calc(100vw - 2.5rem)`;
        // la principal: ancho completo en clásico, ~2/3 en el mosaico
        const heroPx = mosaico ? 760 : 1104;
        const heroSizes = mosaico
          ? '(min-width: 72em) 760px, (min-width: 48em) 66vw, calc(100vw - 2.5rem)'
          : '(min-width: 72em) 1104px, calc(100vw - 2.5rem)';
        return (
          <article
            class="obra obra-panel"
            role="tabpanel"
            id={`panel-${obra.id}`}
            aria-labelledby={`tab-${obra.id}`}
            hidden={oi !== 0}
          >
            <div class:list={['obra-galeria', { 'obra-galeria--mosaico': mosaico }]}>
              <button
                type="button"
                class="obra-foto obra-foto--principal reveal"
                data-lightbox-open="0"
                data-obra={oi}
                data-obra-nombre={obra.titulo}
                aria-haspopup="dialog"
                aria-label={`Ampliar foto: ${obra.fotos[0]!.caption}`}
              >
                {/* width acotado al render real: ~1104px en clásico, ~760px en mosaico */}
                <span class="obra-foto-media">
                  <Image
                    src={obra.fotos[0]!.src}
                    alt={obra.fotos[0]!.alt}
                    layout="constrained"
                    width={heroPx}
                    quality={78}
                    sizes={heroSizes}
                  />
                </span>
                <span class="obra-foto-caption" aria-hidden="true">
                  {obra.fotos[0]!.caption}
                </span>
                <span class="obra-foto-zoom" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  >
                    <circle cx="11" cy="11" r="7" />
                    <path d="m21 21-4.3-4.3M11 8v6M8 11h6" />
                  </svg>
                </span>
              </button>

              <div class="obra-thumbs">
                {thumbsVisibles.map((foto, i) => {
                  // la última miniatura visible lleva el "+N" si quedan fotos ocultas
                  const esMas = fotosOcultas > 0 && i === thumbsVisibles.length - 1;
                  return (
                    <button
                      type="button"
                      class:list={['obra-foto', 'reveal', { 'obra-foto--mas': esMas }]}
                      data-lightbox-open={i + 1}
                      data-obra={oi}
                      data-obra-nombre={obra.titulo}
                      style={`--reveal-delay: calc(var(--stagger-step) * ${i + 1})`}
                      aria-haspopup="dialog"
                      aria-label={
                        esMas
                          ? `Ver todas las fotos de la obra (${obra.fotos.length})`
                          : `Ampliar foto: ${foto.caption}`
                      }
                    >
                      <Image
                        src={foto.src}
                        alt={foto.alt}
                        layout="constrained"
                        width={720}
                        quality={75}
                        sizes={thumbSizes}
                      />
                      {esMas ? (
                        <span class="obra-foto-mas" aria-hidden="true">
                          <span class="obra-foto-mas-num">+{fotosOcultas}</span>
                          <span class="obra-foto-mas-txt">fotos</span>
                        </span>
                      ) : (
                        <>
                          <span class="obra-foto-caption" aria-hidden="true">
                            {foto.caption}
                          </span>
                          <span class="obra-foto-zoom" aria-hidden="true">
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                            >
                              <circle cx="11" cy="11" r="7" />
                              <path d="m21 21-4.3-4.3M11 8v6M8 11h6" />
                            </svg>
                          </span>
                        </>
                      )}
                    </button>
                  );
                })}
              </div>
            </div>

            <div class="obra-info reveal" style="--reveal-delay: calc(var(--stagger-step) * 3)">
              <h3 id={`obra-titulo-${obra.id}`}>{obra.titulo}</h3>
              <p>{obra.descripcion}</p>
              <dl class="obra-datos">
                {obra.datos.map((dato, i) => (
                  <div style={`--row-i: ${i}`}>
                    <dt>{dato.label}</dt>
                    <dd class:list={['obra-dato-valor', { 'obra-dato-valor--num': dato.destacado }]}>
                      {dato.estado ? (
                        <span class="obra-estado">
                          <span class="obra-estado-dot" aria-hidden="true" />
                          {dato.value}
                        </span>
                      ) : dato.finalizada ? (
                        <span class="obra-estado obra-estado--done">
                          <svg
                            class="obra-estado-check"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                          >
                            <path d="m20 6-11 11-5-5" />
                          </svg>
                          {dato.value}
                        </span>
                      ) : (
                        dato.value
                      )}
                    </dd>
                  </div>
                ))}
              </dl>
              <a href="#contacto" class="btn btn--primary">Quiero una obra así</a>
            </div>
          </article>
        );
      })
    }
  </div>
</section>

<dialog id="lightbox" class="lightbox" aria-label="Galería de fotos de la obra">
  <div class="lightbox-inner">
    <button type="button" class="lightbox-btn lightbox-close" data-lightbox-close>
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="5" y1="5" x2="19" y2="19"></line>
        <line x1="19" y1="5" x2="5" y2="19"></line>
      </svg>
      <span class="visually-hidden">Cerrar galería</span>
    </button>

    {
      OBRAS.map((obra, oi) =>
        obra.fotos.map((foto, i) => (
          <figure class="lightbox-slide" data-obra={oi} data-slide={i} hidden>
            <Image
              src={foto.src}
              alt={foto.alt}
              layout="constrained"
              width={1104}
              quality={82}
              sizes="(min-width: 75em) 1104px, calc(100vw - 4rem)"
            />
            <figcaption>
              {foto.caption}{' '}
              <span class="lightbox-count">
                ({i + 1} de {obra.fotos.length})
              </span>
            </figcaption>
          </figure>
        ))
      )
    }

    <p class="visually-hidden" role="status" data-lightbox-status></p>

    <div class="lightbox-nav">
      <button type="button" class="lightbox-btn" data-lightbox-prev>
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        <span class="visually-hidden">Foto anterior</span>
      </button>
