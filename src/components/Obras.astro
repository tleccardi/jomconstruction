    .obra-tabs {
      gap: var(--space-lg);
    }
    .obra-tab {
      padding-bottom: var(--space-sm);
    }
    .obra-tab-nombre {
      font-size: var(--text-sm);
    }
    .obra-tab-meta {
      display: none;
    }

    /* --- Galería → carrusel horizontal swipeable con peek ---
       (NN/g: swipe + media imagen asomando como signifier fuerte;
        Baymard: señalizar fotos ocultas; Chrome/MDN: scroll-snap nativo) */
    .obra-galeria {
      display: flex;
      gap: var(--space-md);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      /* aire vertical para que la sombra de las slides no se recorte
         (overflow-x fuerza overflow-y a auto) */
      padding-block: var(--space-sm);
      scrollbar-width: none;
      overscroll-behavior-x: contain;
    }
    .obra-galeria::-webkit-scrollbar {
      display: none;
    }

    /* los thumbs entran al flex junto a la principal SIN tocar el HTML */
    .obra-thumbs {
      display: contents;
    }

    .obra-galeria .obra-foto {
      flex: 0 0 85%;
      aspect-ratio: 4 / 3; /* altura uniforme entre slides: sin saltos ni huecos al swipe */
      scroll-snap-align: center;
      /* desacople del reveal: la slide SIEMPRE renderiza visible dentro del
         scroller (el IntersectionObserver vertical no es fiable para ítems
         scrolleados en horizontal). El header de la sección conserva su reveal. */
      opacity: 1;
      transform: none;
    }
    /* la principal envuelve su img en .obra-foto-media: que también llene el box 4:3 */
    .obra-galeria .obra-foto-media {
      height: 100%;
    }
    .obra-galeria .obra-foto img {
      height: 100%;
      object-fit: cover; /* recorta sólo el preview; el lightbox muestra el frame completo (contain) */
      transform: none;
    }
    /* sin hover en touch: la lupa "tocá para ampliar" queda siempre visible */
    .obra-galeria .obra-foto-zoom {
      opacity: 1;
      transform: none;
    }

    /* indicador de carrusel: mejora progresiva (Chrome 135+). Sin soporte,
       el peek de la slide siguiente sigue siendo el cue (NN/g: peek > dots). */
    @supports (scroll-marker-group: after) {
      .obra-galeria {
        scroll-marker-group: after;
      }
      .obra-galeria::scroll-marker-group {
        display: flex;
        justify-content: center;
        gap: var(--space-xs);
        padding-top: var(--space-xs);
      }
      .obra-galeria .obra-foto::scroll-marker {
        content: '';
        width: 0.5rem;
        height: 0.5rem;
        border-radius: var(--radius-full);
        background: var(--color-line);
        transition: background-color var(--speed-fast) var(--ease-out);
      }
      .obra-galeria .obra-foto::scroll-marker:target-current {
        background: var(--color-cobalt);
      }
    }

    /* El grupo de dots (::scroll-marker-group) se inserta como un ítem más del
       grid .obra, así que heredaba su gap de 48px y quedaba flotando lejos de la
       imagen. Anulamos el row-gap (los dots quedan pegados a la galería, sólo el
       padding de los markers los separa) y devolvemos la separación a la ficha
       vía margin-top. Sin soporte de scroll-marker no hay grupo: el margin-top
       deja la galería↔ficha en los mismos 48px de siempre. */
    .obra {
      row-gap: 0;
    }
    .obra-info {
      margin-top: var(--space-2xl);
    }

    /* --- Ficha de datos → 1 columna legible --- */
    .obra-datos {
      grid-template-columns: 1fr;
      padding: var(--space-lg); /* menos lateral que el --space-xl de base: más ancho útil en 360px */
    }
    /* el nth-child(-n+2) de base limpia los 2 primeros (pensado para 2-col);
       en 1-col devolvemos el hairline al 2º ítem (el 1º sigue limpio) */
    .obra-datos > div:nth-child(2) {
      padding-top: var(--space-md);
      border-top: 1px solid var(--color-line);
    }

    /* --- CTA contextual a ancho completo --- */
    .obra-info .btn {
      width: 100%;
    }

    /* --- Lightbox → más imagen + flechas legibles sobre la foto --- */
    .lightbox {
      padding: var(--space-lg) var(--space-md);
    }
    /* la imagen deja lugar para cruz (arriba) + caption + flechas (abajo) sin desbordar 100dvh */
    .lightbox-slide img {
      max-height: 60dvh;
    }
    /* flechas FUERA de la imagen: barra inferior en la banda oscura, al ancho
       de la foto, prev a la izquierda / next a la derecha (la posición lateral
       comunica la dirección). En mobile la foto ocupa casi todo el ancho y no
       hay carril lateral, así que el lugar correcto es debajo y al alcance del
       pulgar. Se mantienen como alternativa de puntero simple al swipe (WCAG 2.5.1). */
    .lightbox-nav {
      position: static;
      transform: none;
      margin-top: var(--space-md);
      padding-inline: var(--space-md);
    }
    /* iconos SIN círculo: no tapan nada y se leen por un halo de sombra. */
    .lightbox-btn svg {
      filter: drop-shadow(0 1px 2px rgb(5 19 65 / 0.75))
        drop-shadow(0 0 5px rgb(5 19 65 / 0.55));
    }
    /* cruz de cierre: ARRIBA Y POR FUERA de la imagen (en la banda oscura),
       anclada al borde superior de .lightbox-inner — no al viewport — para que
       un transform residual del <dialog> no la desplace. Sin chip: el icono
       blanco + halo se lee sobre el backdrop oscuro. */
    .lightbox-close {
      position: absolute;
      top: auto;
      bottom: calc(100% + var(--space-xs));
      right: 0;
    }
  }
</style>

<script>
  // ---------- Selector de obras (tabs, patrón WAI-ARIA) ----------
  // Activación AUTOMÁTICA: las flechas mueven foco y activan a la vez. Es la
  // recomendación del APG cuando los paneles están precargados en el DOM
  // (acá lo están: Astro renderiza todas las obras, sólo se ocultan con [hidden]).
  const tablist = document.querySelector<HTMLElement>('.obra-tabs[role="tablist"]');

  if (tablist) {
    const tabs = Array.from(tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const panelDe = (tab: HTMLButtonElement) =>
      document.getElementById(tab.getAttribute('aria-controls') ?? '');

    const activar = (tab: HTMLButtonElement, { foco = true } = {}) => {
      if (tab.getAttribute('aria-selected') === 'true') {
        if (foco) tab.focus();
        return;
      }
      tabs.forEach((t) => {
        const activo = t === tab;
        t.setAttribute('aria-selected', activo ? 'true' : 'false');
        t.tabIndex = activo ? 0 : -1;
        const panel = panelDe(t);
        if (panel) panel.hidden = !activo;
      });
      const panel = panelDe(tab);
      if (panel) {
        // el contenido .reveal del panel recién mostrado puede no haber sido
        // observado nunca (estaba en display:none): lo marcamos visible a mano
        panel.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
        if (!reduce) {
          panel.classList.remove('is-entering');
          void panel.offsetWidth; // reinicia la animación de cross-fade
          panel.classList.add('is-entering');
        }
      }
      // en mobile la tira de chips scrollea: recentrar el activo aunque el cambio
      // venga de un tap (con foco:false el navegador no hace scroll-into-view solo).
      // Gateado por overflow real: en ≥48em los chips entran y esto es no-op, así
      // que el desktop aprobado no cambia.
      if (tablist.scrollWidth > tablist.clientWidth) {
        tab.scrollIntoView({
          inline: 'center',
          block: 'nearest',
          behavior: reduce ? 'auto' : 'smooth',
        });
      }
      if (foco) tab.focus();
    };

    // click: activa sin re-robar el foco (el botón ya lo recibe al clickear)
    tablist.addEventListener('click', (event) => {
      const tab = (event.target as HTMLElement).closest<HTMLButtonElement>('[role="tab"]');
      if (tab) activar(tab, { foco: false });
    });

    // teclado: flechas / Home / End mueven foco + activan
    tablist.addEventListener('keydown', (event) => {
      const i = tabs.indexOf(document.activeElement as HTMLButtonElement);
      if (i < 0) return;
      let next = -1;
      if (event.key === 'ArrowRight' || event.key === 'ArrowDown') next = (i + 1) % tabs.length;
      else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp')
        next = (i - 1 + tabs.length) % tabs.length;
      else if (event.key === 'Home') next = 0;
      else if (event.key === 'End') next = tabs.length - 1;
      if (next >= 0) {
        event.preventDefault();
        activar(tabs[next]!);
      }
    });
  }

  // ---------- Lightbox (por obra) ----------
  const lightbox = document.getElementById('lightbox') as HTMLDialogElement | null;

  if (lightbox) {
    const slides = Array.from(lightbox.querySelectorAll<HTMLElement>('[data-slide]'));
    const status = lightbox.querySelector<HTMLElement>('[data-lightbox-status]');
    let currentObra = 0;
    let current = 0;

    // las fotos de la obra activa, en orden
    const grupo = (obra: number) => slides.filter((s) => Number(s.dataset.obra) === obra);

    const show = (index: number) => {
      const g = grupo(currentObra);
      if (!g.length) return;
      current = (index + g.length) % g.length;
      slides.forEach((slide) => {
        slide.hidden = true;
      });
      const activa = g[current];
      if (activa) activa.hidden = false;
      // anuncia el cambio de foto a lectores de pantalla (WCAG 4.1.3)
      const caption = activa?.querySelector('figcaption')?.textContent?.trim();
      if (status && caption) status.textContent = caption;
    };

    document.querySelectorAll<HTMLButtonElement>('[data-lightbox-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        currentObra = Number(btn.dataset.obra ?? 0);
        const nombre = btn.dataset.obraNombre;
        lightbox.setAttribute(
          'aria-label',
          nombre ? `Galería de fotos — ${nombre}` : 'Galería de fotos de la obra'
        );
        show(Number(btn.dataset.lightboxOpen ?? 0));
        lightbox.showModal();
      });
    });

    lightbox.querySelector('[data-lightbox-close]')?.addEventListener('click', () => {
      lightbox.close();
    });

    lightbox.querySelector('[data-lightbox-prev]')?.addEventListener('click', () => {
      show(current - 1);
    });

    lightbox.querySelector('[data-lightbox-next]')?.addEventListener('click', () => {
      show(current + 1);
    });

    lightbox.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') show(current - 1);
      if (event.key === 'ArrowRight') show(current + 1);
    });

    // Cerrar al clickear el fondo (fuera del contenido)
    lightbox.addEventListener('click', (event) => {
      if (event.target === lightbox) lightbox.close();
    });

    // Swipe entre fotos en touch: gesto ADICIONAL a flechas/teclado.
    // Reutiliza show(), así que no toca el foco del <dialog>, el role=status
    // ni los aria-labels. Sólo cuenta como swipe un gesto horizontal claro
    // (ignora scroll/tap vertical).
    let touchStartX: number | null = null;
    let touchStartY: number | null = null;
    lightbox.addEventListener(
      'touchstart',
      (event) => {
        const t = event.changedTouches[0];
        if (!t) return;
        touchStartX = t.clientX;
        touchStartY = t.clientY;
      },
      { passive: true }
    );
    lightbox.addEventListener(
      'touchend',
      (event) => {
        if (touchStartX === null || touchStartY === null) return;
        const t = event.changedTouches[0];
        if (t) {
          const dx = t.clientX - touchStartX;
          const dy = t.clientY - touchStartY;
          if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
            show(dx < 0 ? current + 1 : current - 1);
          }
        }
        touchStartX = null;
        touchStartY = null;
      },
      { passive: true }
    );
  }
</script>
