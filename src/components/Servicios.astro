---
import { waLink } from '../config';

interface Servicio {
  titulo: string;
  descripcion: string;
  consulta: string;
  icono: string; // path data del ícono (stroke)
}

const SERVICIOS: Servicio[] = [
  {
    titulo: 'Obra nueva',
    descripcion:
      'Construcción integral desde los cimientos: viviendas, edificios y locales. Del plano a la entrega, con un solo responsable.',
    consulta: 'Hola JOM Construction, quiero pedir presupuesto para una obra nueva.',
    icono:
      'M3 21h18M5 21V7l7-4 7 4v14M9 21v-4h6v4M9 12h.01M12 12h.01M15 12h.01M9 9h.01M12 9h.01M15 9h.01',
  },
  {
    titulo: 'Desarrollos residenciales',
    descripcion:
      'Ejecución de edificios y conjuntos de vivienda para desarrolladores e inversores, con avances certificados etapa por etapa.',
    consulta: 'Hola JOM Construction, quiero hablar sobre la ejecución de un desarrollo residencial.',
    icono:
      'M3 21h18M6 21V9h5v12M11 21V4h7v17M14 8h.01M14 12h.01M14 16h.01M8 12h.01M8 16h.01',
  },
  {
    titulo: 'Refacciones y ampliaciones',
    descripcion:
      'Remodelamos y ampliamos casas, departamentos y locales en uso, con obra prolija, tiempos acordados y mínimas molestias.',
    consulta: 'Hola JOM Construction, quiero pedir presupuesto para una refacción o ampliación.',
    icono:
      'M14.7 6.3a4 4 0 0 0-5.06 5.06L3 18v3h3l6.64-6.64a4 4 0 0 0 5.06-5.06l-2.85 2.85-2.12-2.12 2.97-2.73Z',
  },
  {
    titulo: 'Obra para empresas',
    descripcion:
      'Plantas, depósitos, oficinas y locales comerciales. Normativa, seguridad e higiene y coordinación con tu operación diaria.',
    consulta: 'Hola JOM Construction, quiero pedir presupuesto para una obra para mi empresa.',
    icono: 'M3 21h18M5 21V8l5 3V8l5 3V5h4v16M16 9h.01M16 13h.01M16 17h.01M8 16h.01M8 19h.01',
  },
  {
    titulo: 'Dirección y gestión de obra',
    descripcion:
      'Dirección técnica, cómputo y presupuesto, y coordinación de gremios para que tu proyecto avance con números claros.',
    consulta: 'Hola JOM Construction, necesito dirección o gestión para una obra.',
    icono:
      'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2M9 5v2h6V5M9 12h6M9 16h4',
  },
];
---

<section id="servicios" class="section servicios">
  <div class="container">
    <header class="section-head">
      <p class="kicker reveal">Servicios</p>
      <h2 class="section-title reveal" style="--reveal-delay: calc(var(--stagger-step) * 1)">
        Qué construimos
      </h2>
      <p class="section-lede reveal" style="--reveal-delay: calc(var(--stagger-step) * 2)">
        Ejecutamos obra para terceros: empresas, desarrolladores y particulares. Estos son los
        frentes donde más valor aportamos.
      </p>
    </header>

    {/* Mobile (≤47.99em): .servicios-grid se vuelve un carrusel scroll-snap con
        dots nativos (::scroll-marker, igual que Obras) y el CTA cae debajo del
        riel. Desktop (≥48em): .servicios-layout es la grilla y .servicios-grid usa
        display:contents → las 5 cards + el CTA son los mismos 6 ítems 3×2 de
        siempre. Por eso el desktop aprobado no cambia. */}
    <div class="servicios-layout">
      <ul class="servicios-grid" role="list" aria-label="Servicios">
        {
          SERVICIOS.map((servicio, i) => (
            <li
              class="servicio-card reveal"
              style={`--reveal-delay: calc(var(--stagger-step) * ${i})`}
            >
              <div class="servicio-card-inner">
                <span class="servicio-icono" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d={servicio.icono} />
                  </svg>
                </span>
                <h3>{servicio.titulo}</h3>
                <p>{servicio.descripcion}</p>
                <a
                  href={waLink(servicio.consulta)}
                  target="_blank"
                  rel="noopener"
                  class="servicio-link"
                >
                  <span class="servicio-link-label">Consultar por este servicio</span>
                  <span class="servicio-flecha" aria-hidden="true">→</span>
                </a>
              </div>
            </li>
          ))
        }
      </ul>

      {/* Dots del carrusel (mobile): los genera el <script> de abajo como botones
          reales — funcionan en todo navegador, iOS Safari incluido, a diferencia
          de ::scroll-marker que sólo existe en Chromium 135+ (por eso se veían en
          la emulación del navegador de escritorio pero no en el celu real). Sin JS
          quedan vacíos y ocultos: el peek de la card siguiente sigue siendo el cue. */}
      <nav class="servicios-dots" aria-label="Navegación del carrusel de servicios" data-servicios-dots></nav>

      {/* CTA: en desktop es la 6ª celda de la grilla; en mobile sale del riel y
          queda fijo, full-width, debajo (un CTA de conversión no debe esconderse
          detrás de swipes). */}
      <div
        class="servicio-card servicio-card--cta reveal"
        style={`--reveal-delay: calc(var(--stagger-step) * ${SERVICIOS.length})`}
      >
        <div class="servicio-card-inner">
          <p>¿No sabés exactamente qué necesita tu proyecto? Contanos y te orientamos.</p>
          <a href="#contacto" class="btn btn--gold">Pedí tu presupuesto sin cargo</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .servicios {
    background: var(--color-white);
  }

  /* ---------- Kicker: la línea roja se "dibuja" al entrar (mismo gesto que
     Obras/Proceso/Diferenciadores). El header recupera la entrada .reveal que
     tienen el resto de las secciones; sin esto Servicios "aparecía de golpe". ---------- */
  html:not(.no-js) .kicker::before {
    transform-origin: left;
    transform: scaleX(0);
  }

  html:not(.no-js) .kicker.is-visible::before {
    animation: servicios-kicker-line var(--speed-cinematic) var(--ease-out) 120ms forwards;
  }

  @keyframes servicios-kicker-line {
    to {
      transform: scaleX(1);
    }
  }

  /* La grilla 3×2 vive ahora en .servicios-layout (antes en .servicios-grid) para
     poder sacar el CTA del riel en mobile sin tocar el desktop. En ≥48em
     .servicios-grid usa display:contents → sus 5 <li> + el CTA quedan como los
     mismos 6 ítems de la grilla. Layout computado ≥48em: idéntico al aprobado. */
  .servicios-layout {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: var(--space-lg);
  }

  /* Desktop: exactamente 3 columnas (5 servicios + 1 card destacada = 3×2).
     Mobile/tablet conserva el auto-fit original; lo afinamos en su pasada. */
  @media (min-width: 64em) {
    .servicios-layout {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* El <ul> ya no pinta caja propia en desktop: sus <li> ascienden a la grilla
     de .servicios-layout. En mobile recupera caja y se vuelve el riel. */
  .servicios-grid {
    display: contents;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  /* La <li> solo posiciona y revela: .reveal (global.css) aporta opacity +
     translateY de entrada, escalonado por --reveal-delay. Todo el hover vive en
     .servicio-card-inner para no pelear con el transform ni heredar el
     transition-delay del reveal — mismo patrón que MetricsBar (.metric / -inner). */
  .servicio-card {
    display: flex;
  }

  .servicio-card-inner {
    position: relative;
    isolation: isolate;
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl);
    background: var(--color-cream);
    border: 1px solid var(--color-line);
    border-top: 2px solid var(--color-sand); /* terminación superior dorada (igual que la ficha de obra) */
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm); /* profundidad en reposo: deja de verse plana */
    transition:
      transform var(--speed-base) var(--ease-interactive),
      box-shadow var(--speed-base) var(--ease-interactive),
      border-color var(--speed-base) var(--ease-interactive);
  }

  .servicio-card:hover .servicio-card-inner,
  .servicio-card:focus-within .servicio-card-inner {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    /* sin recolorear el borde a cobalto: la card solo se eleva, la corona dorada queda */
  }

  /* Ícono: par cobalto + dorado. Gradiente para profundidad + anillo dorado
     sutil; en hover escala y gana glow dorado (--shadow-gold-hover). */
  .servicio-icono {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    margin-bottom: var(--space-md);
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--color-cobalt), var(--color-cobalt-deep));
    color: var(--color-sand-light);
    box-shadow: inset 0 0 0 1px rgb(228 220 176 / 0.25);
    transition:
      transform var(--speed-base) var(--ease-interactive),
      box-shadow var(--speed-base) var(--ease-interactive);
  }

  .servicio-icono svg {
    width: 1.625rem;
    height: 1.625rem;
  }

  .servicio-card:hover .servicio-icono,
  .servicio-card:focus-within .servicio-icono {
    transform: scale(1.06);
    box-shadow:
      inset 0 0 0 1px rgb(228 220 176 / 0.4),
      var(--shadow-gold-hover);
  }

  .servicio-card h3 {
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-ink);
  }

  .servicio-card p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    flex-grow: 1;
  }

  .servicio-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
    min-height: 2.75rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-cobalt);
    text-decoration: none;
  }

  /* Subrayado que se "dibuja" con scaleX (sin layout shift) */
  .servicio-link-label {
    position: relative;
  }

  .servicio-link-label::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--speed-base) var(--ease-interactive);
  }

  /* La flecha avanza en X */
  .servicio-flecha {
    transition: transform var(--speed-base) var(--ease-interactive);
  }

  .servicio-card:hover .servicio-link-label::after,
  .servicio-card:focus-within .servicio-link-label::after {
    transform: scaleX(1);
  }

  .servicio-card:hover .servicio-flecha,
  .servicio-card:focus-within .servicio-flecha {
    transform: translateX(6px);
  }

  /* ---- Card destacada (cobalto): clímax de la grilla, absorbe el viejo CTA ---- */
  .servicio-card--cta .servicio-card-inner {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-lg);
    /* mismo cobalto profundo que el header scrolleado (rgb 2 24 110 ≈ --color-cobalt-deep):
       la card lee como un plano más hondo, no como el cobalto brillante de los iconitos */
    background: var(--color-cobalt-deep);
    border-color: transparent;
    border-top-color: var(--color-red); /* terminación superior roja (el otro color de marca) */
    color: var(--color-white);
    box-shadow: var(--shadow-cta);
  }

  .servicio-card--cta:hover .servicio-card-inner,
  .servicio-card--cta:focus-within .servicio-card-inner {
    box-shadow: var(--shadow-cta-hover);
    border-color: transparent;
    border-top-color: var(--color-red); /* la terminación roja se mantiene en hover */
  }

  .servicio-card--cta p {
    max-width: 22rem;
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--color-white);
    flex-grow: 0;
  }

  /* Dots del carrusel: sólo se muestran en mobile (ver media query). En desktop
     y sin JS quedan ocultos para no colarse como 7ª celda en la grilla 3×2. */
  .servicios-dots {
    display: none;
  }

  /* ============================================================
     CARRUSEL MOBILE (≤47.99em) — scroll-snap nativo.
     Todo el carrusel vive acá adentro: a ≥48em no se evalúa ninguna de estas
     reglas, así que la grilla 3×2 aprobada queda intacta byte por byte.
     ============================================================ */
  @media (max-width: 47.99em) {
    .servicios-layout {
      display: block;
    }

    /* el <ul> deja de ser display:contents y pasa a ser el riel horizontal */
    .servicios-grid {
      display: flex;
      flex-wrap: nowrap;
      gap: var(--space-md);
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      /* El riel queda DENTRO del padding del .container (igual que el carrusel de
         fotos de Obras): corta en el límite del contenido, no en el borde físico de
         la pantalla. Antes hacía full-bleed con margin-inline negativo y la card del
         peek se pasaba del límite horizontal de la página (sin gutter a la derecha). */
      /* aire vertical: que overflow no recorte el focus-ring ni el lift -6px */
      padding-block: var(--space-sm);
      scrollbar-width: none;
      overscroll-behavior-x: contain;
      -webkit-overflow-scrolling: touch;
    }

    .servicios-grid::-webkit-scrollbar {
      display: none;
    }

    .servicios-grid .servicio-card {
      flex: 0 0 85%; /* 1 card + ~1.1: asoma la siguiente como señal de "hay más" */
      scroll-snap-align: start;
    }

    /* compactar las cards DEL CARRUSEL en mobile (scoped a .servicios-grid, así el
       CTA y todo el desktop ≥48em conservan el padding holgado original): menos
       padding, ícono más chico y gaps internos más ajustados. */
    .servicios-grid .servicio-card-inner {
      padding: var(--space-lg);
      gap: var(--space-xs);
    }

    .servicios-grid .servicio-icono {
      width: 2.75rem;
      height: 2.75rem;
      margin-bottom: var(--space-sm);
    }

    .servicios-grid .servicio-icono svg {
      width: 1.5rem;
      height: 1.5rem;
    }

    /* título un punto más chico y descripción con interlineado snug: las dos
       palancas que más bajan el alto sin tocar el contenido ni la jerarquía
       (título display 18px sobre cuerpo 15px). */
    .servicios-grid .servicio-card h3 {
      font-size: var(--text-md);
    }

    .servicios-grid .servicio-card p {
      line-height: var(--leading-snug);
    }

    /* reveal × carrusel: el IntersectionObserver (Layout.astro) usa el viewport
       como root → las cards fuera de pantalla en X nunca intersectan y quedarían
       en opacity:0 (y no dispara en scroll programático). Dentro del riel
       desactivamos el reveal: las cards entran ya visibles. El header y el CTA
       (fuera del riel) conservan su reveal normal. */
    .servicios-grid .servicio-card.reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    /* indicador de carrusel: dots reales (botones) que monta el <script> — andan
       en todo navegador, iOS Safari incluido, donde ::scroll-marker (Chromium 135+)
       no existe. Son además tappables (vía extra de navegación al swipe, WCAG 2.5.1).
       Sin JS el contenedor queda vacío y el peek sigue siendo el cue (NN/g: peek > dots). */
    .servicios-dots {
      display: flex;
      justify-content: center;
      gap: var(--space-xs);
      padding-top: var(--space-md);
    }
    /* sin JS no se generan botones: el contenedor vacío no ocupa lugar */
    .servicios-dots:empty {
      display: none;
    }
    /* :global() porque los botones los crea el <script> con createElement y NO
       llevan el atributo de scope de Astro — sin :global las reglas scoped no los
       alcanzarían. Quedan acotados al wrapper .servicios-dots (sí scopeado). */
    .servicios-dots :global(.servicios-dot) {
      display: grid;
      place-content: center;
      /* área táctil 24px (WCAG 2.5.8) con el punto visible chico y centrado */
      width: 1.5rem;
      height: 1.5rem;
      border-radius: var(--radius-full);
    }
    .servicios-dots :global(.servicios-dot::before) {
      content: '';
      width: 0.5rem;
      height: 0.5rem;
      border-radius: var(--radius-full);
      background: var(--color-line);
      transition:
        background-color var(--speed-fast) var(--ease-out),
        transform var(--speed-fast) var(--ease-out);
    }
    /* card activa: punto cobalto un punto más grande (mismo lenguaje que el chip
       activo de los tabs de Obras) */
    .servicios-dots :global(.servicios-dot[aria-current='true']::before) {
      background: var(--color-cobalt);
      transform: scale(1.25);
    }

    /* CTA full-width debajo del carrusel (sale del riel). Margen amplio para
       despegarlo de los dots: el indicador pertenece al riel, no al CTA. */
    .servicio-card--cta {
      margin-top: var(--space-2xl);
    }
  }

  /* prefers-reduced-motion: global.css ya neutraliza .reveal y lleva las
     transiciones a ~0ms, así el hover salta al estado final sin animar. Nada
     queda oculto detrás del movimiento (flecha, subrayado y acento parten de un
     estado legible), por eso no se necesita nada extra acá. */
</style>

<script>
  // ---------- Dots del carrusel de servicios (sólo mobile) ----------
  // Reemplazo cross-browser de ::scroll-marker (Chromium 135+, ausente en iOS
  // Safari/Firefox): botones reales que reflejan la card activa y permiten saltar
  // a cada servicio. Se montan SÓLO cuando el riel es un scroller real (≤47.99em)
  // y se desarman en ≥48em — donde .servicios-grid es display:contents (la grilla
  // 3×2 no lleva dots). La card activa = la más centrada en el riel, calculada en
  // un handler de scroll del PROPIO riel (no de window), throttleado con rAF.
  const riel = document.querySelector<HTMLElement>('.servicios-grid');
  const dotsWrap = document.querySelector<HTMLElement>('[data-servicios-dots]');

  if (riel && dotsWrap) {
    const mql = window.matchMedia('(max-width: 47.99em)');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    const cards = Array.from(riel.querySelectorAll<HTMLElement>('.servicio-card'));
    let dots: HTMLButtonElement[] = [];
    let onScroll: (() => void) | null = null;

    // marca como activa la card cuyo centro queda más cerca del centro del riel
    const update = () => {
      const rect = riel.getBoundingClientRect();
      const center = rect.left + rect.width / 2;
      let best = 0;
      let bestDist = Infinity;
      cards.forEach((c, i) => {
        const r = c.getBoundingClientRect();
        const dist = Math.abs(r.left + r.width / 2 - center);
        if (dist < bestDist) {
          bestDist = dist;
          best = i;
        }
      });
      dots.forEach((d, i) =>
        i === best ? d.setAttribute('aria-current', 'true') : d.removeAttribute('aria-current')
      );
    };

    const build = () => {
      dots = cards.map((card, i) => {
        const titulo = card.querySelector('h3')?.textContent?.trim() ?? `servicio ${i + 1}`;
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'servicios-dot';
        dot.setAttribute('aria-label', `Ir a ${titulo}`);
        // tap en el dot: centra la card (navegación alternativa al swipe, WCAG 2.5.1)
        dot.addEventListener('click', () => {
          card.scrollIntoView({
            inline: 'center',
            block: 'nearest',
            behavior: reduce.matches ? 'auto' : 'smooth',
          });
        });
        dotsWrap.appendChild(dot);
        return dot;
      });

      // scroll del riel → un solo recálculo por frame (rAF), no por evento
      let ticking = false;
      onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      };
      riel.addEventListener('scroll', onScroll, { passive: true });
      update(); // estado inicial: card 0 activa
    };

    const teardown = () => {
      if (onScroll) riel.removeEventListener('scroll', onScroll);
      onScroll = null;
      dotsWrap.replaceChildren();
      dots = [];
    };

    // construye en mobile, desarma en desktop (y al cruzar el breakpoint)
    const sync = () => {
      if (mql.matches) {
        if (!onScroll) build();
      } else if (onScroll) {
        teardown();
      }
    };

    sync();
    mql.addEventListener('change', sync);
  }
</script>
